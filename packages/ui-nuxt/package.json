{
  "name": "@noy-db/ui-nuxt",
  "version": "0.3.0-pre.2",
  "description": "Nuxt binding for @noy-db/ui: schema-driven list + detail components + the Nuxt module. Domain-free; consumes collection.describe().",
  "type": "module",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db-ui/tree/main/packages/ui-nuxt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vLannaAi/noy-db-ui.git",
    "directory": "packages/ui-nuxt"
  },
  "bugs": {
    "url": "https://github.com/vLannaAi/noy-db-ui/issues"
  },
  "keywords": [
    "noy-db",
    "nuxt",
    "nuxt-module",
    "schema-driven",
    "data-table",
    "vue"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "default": "./dist/module.js"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "default": "./dist/module.js"
    },
    "./core": "./dist/runtime/core/index.ts",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup && unocss \"src/runtime/{components,internal}/**/*.vue\" --config uno.config.ts -o dist/style.css",
    "build:css": "unocss \"src/runtime/{components,internal}/**/*.vue\" --config uno.config.ts -o dist/style.css",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "@noy-db/hub": "^0.3.0-pre.2",
    "vue": "^3.5.0",
    "@nuxt/kit": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    }
  },
  "dependencies": {
    "@noy-db/ui": "workspace:*"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@noy-db/hub": "^0.3.0-pre.2",
    "@noy-db/ui": "workspace:*",
    "@nuxt/kit": "^4.0.0",
    "@nuxt/schema": "^4.0.0",
    "@unocss/cli": "^66.7.2",
    "nuxt": "^4.0.0",
    "unocss": "^66.7.2",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
