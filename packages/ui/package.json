{
  "name": "@noy-db/ui",
  "version": "0.3.0-pre.1",
  "description": "Framework-agnostic base of the noy-db UI family: the schema-driven search/list engine + design tokens. Domain-free; consumes collection.describe().",
  "type": "module",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db-ui/tree/main/packages/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vLannaAi/noy-db-ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/vLannaAi/noy-db-ui/issues"
  },
  "keywords": [
    "noy-db",
    "schema-driven",
    "search",
    "data-table",
    "vue"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@noy-db/hub": "^0.3.0-pre.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@noy-db/hub": "^0.3.0-pre.2",
    "@noy-db/to-memory": "^0.3.0-pre.1",
    "vue": "^3.5.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}